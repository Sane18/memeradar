# ─────────────────────────────────────────────────────────────
# MemeRadar environment variables
# Copy this file to `.env.local` and fill in. All have FREE tiers.
# The app runs with live Jupiter data even if you leave the others blank.
# ─────────────────────────────────────────────────────────────

# Privy — auth + embedded Solana wallets (Apple / Google sign-in)
# Create an app at https://dashboard.privy.io  → Settings → App ID
NEXT_PUBLIC_PRIVY_APP_ID=

# BirdEye — OHLCV charts, holders, live trades (free tier)
# Get a key at https://birdeye.so/data-api  (Standard / free plan)
# Server-side only — never prefixed with NEXT_PUBLIC.
BIRDEYE_API_KEY=

# Alchemy — Solana RPC (balances, sending tx). Free tier.
# Create an app at https://dashboard.alchemy.com  → Solana Mainnet
# Falls back to the public RPC if left blank.
NEXT_PUBLIC_SOLANA_RPC=

# Optional: public site URL (used for share/OG tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
